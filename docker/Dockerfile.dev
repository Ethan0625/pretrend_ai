FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PRETREND_ENV=test
ENV PRETREND_DATA_DIR=/app/data
ENV PRETREND_LOG_DIR=/app/logs

WORKDIR /app

COPY requirements/ ./requirements/
RUN pip install --no-cache-dir -r requirements/ci.txt

COPY README.md pyproject.toml requirements.txt conftest.py reproduce.py ./
COPY .github/ ./.github/
COPY docker-compose.yml .dockerignore .env.example ./
COPY docker/ ./docker/
COPY alembic.ini ./
COPY migrations/ ./migrations/
COPY dags/ ./dags/
COPY src/ ./src/
COPY tests/ ./tests/
COPY docs/ ./docs/

RUN pip install --no-cache-dir -e .

CMD ["pytest", "--gate", "fast", "-q", "--tb=short"]
