# Pretrend Observability Dashboard - Frontend env
# Docker-first default uses same-origin proxy: /api/v1/* and /health.
# Docker nginx injects PRETREND_API_KEY server-side; VITE_API_KEY is for Vite dev only.
VITE_API_URL=
VITE_API_KEY=replace-me-with-actual-key
VITE_API_PROXY_TARGET=http://api:8000
