FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PRETREND_ENV=test
ENV PRETREND_DATA_DIR=/app/data
ENV PRETREND_LOG_DIR=/app/logs

WORKDIR /app

COPY README.md pyproject.toml requirements_api.txt requirements_ci.txt ./
COPY docker-compose.yml Dockerfile.api Dockerfile.dev ./
COPY .dockerignore Dockerfile.api.dockerignore Dockerfile.dev.dockerignore .env.example ./
RUN pip install --no-cache-dir -r requirements_ci.txt

COPY alembic.ini ./
COPY migrations/ ./migrations/
COPY scripts/ ./scripts/
COPY dags/ ./dags/
COPY src/ ./src/
COPY tests/ ./tests/
COPY docs/ ./docs/

RUN pip install --no-cache-dir -e .

CMD ["pytest", "-q", "--tb=short"]
